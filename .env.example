# App Store Connect API credentials
# Create a key at: https://appstoreconnect.apple.com/access/integrations/api
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
# Or supply the key inline instead of a path:
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIG..."

# Optional: required for sales/finance report tools
# ASC_VENDOR_NUMBER=00000000

# Optional: App Store Server API (StoreKit 2)
# ASC_BUNDLE_ID=com.example.app
# ASC_APP_APPLE_ID=1234567890
# ASC_ENVIRONMENT=Sandbox   # or Production
